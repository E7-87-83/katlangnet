Program         = Algorithm ;

Algorithm       = { AlgorithmItem } ;
AlgorithmItem   = OpenDeclaration | PropertyDefinition | ClauseDefinition | ExplicitOutputDefinition | OutputLine ;

OpenDeclaration = "open" OpenTargetList ;
OpenTargetList  = OpenTarget { "," OpenTarget } ;
                  (* `open` is a declaration/import directive, not an output
                     expression: its target list is comma-separated only.
                     open A, B, C opens three targets; string targets use
                     single quotes (open 'url', A). Each algorithm allows at
                     most one open declaration. The first target must begin
                     on the same physical line as "open". Comma keeps its
                     normal explicit line-continuation behavior — open A,
                     newline B and open A newline , B both continue the
                     list — and a leading "." continues a dotted target
                     (open A newline .B is open A.B), but plain newline
                     adjacency never continues open: open Math newline
                     Math.Pi is an open plus a report row. ";" and same-line
                     adjacency are NOT open-target separators (open A ; B
                     and open A B report a missing-comma diagnostic).
                     "..." is the spread operator and is NOT valid in open
                     targets for any atom kind, including string targets:
                     open A..., open A...B, open A, B..., and open 'url'...
                     report a targeted parse diagnostic — use comma for
                     multiple targets. The parser validates each target as
                     an individual Lean-compatible open form. *)
OpenTarget      = StringLiteral              (* sugar: open 'url' → open load('url') *)
                | Identifier                 (* resolve form *)
                | DottedOpenPath             (* argumentless dot-call path, e.g. Lib.Sub *)
                | ParenBundleExpr ;          (* parenthesized/block open target *)
DottedOpenPath  = Identifier { "." Identifier } ;

PropertyDefinition = [ "public" ] NonOutputIdentifier "=" PropertyBody ;
PropertyBody       = Algorithm ;

ClauseDefinition = [ "public" ] NonOutputIdentifier "(" Pattern ")" "=" OutputBundle ;
                     (* Clause-style definition: Name(pattern) = body.
                        Recognized only in definition position;
                        in expression position Name(...) remains an ordinary call.
                        Public visibility is family-level: every clause in a
                        same-name family must either include `public` or omit it.
                        KatLang supports recursive parameter patterns in ordinary
                        algorithm definitions and conditional branch heads. A
                        same-name group with exactly one clause whose head consists
                        only of captures and structural sequence-value patterns elaborates as an
                        ordinary explicit parameter list, e.g. PairSum((x, y)) or
                        CountSequenceValue((values...)). A sequence-value parameter pattern
                        consumes one parent-level argument slot, so F((head,
                        tail...), suffix) takes one sequence-value first argument and
                        binds its immediate contents. Variadic captures consume
                        sibling values at their own pattern-list level.
                        Multi-clause families and literal/mixed heads elaborate as
                        conditional algorithms.
                        `Output(...) = ...` is invalid; declare parameters and
                        branches on the enclosing algorithm instead. *)

ExplicitOutputDefinition = "Output" "=" OutputBundle ;
                     (* "Output = ..." is a definition: its body is
                        line-bounded like every definition body (a newline ends it).
                        Explicit and implicit output cannot mix in the same
                        algorithm in either direction. Write Output = (A, B)
                        for one sequence-valued explicit output, or Output = A, B for
                        separate explicit output slots. *)

Pattern            = PatternAtom { "," PatternAtom } ;
PatternAtom        = Identifier [ "..." ]          (* bind; except reserved binder name "empty";
                                                       "..." is valid only for ordinary recursive
                                                       explicit parameter patterns, at most once per
                                                       sibling pattern level, and not with "~" *)
                   | [ "-" ] NumberLiteral         (* litInt    *)
                   | StringLiteral                 (* litString *)
                   | "(" Pattern ")" ;             (* sequence-value pattern; always structural, even for singletons *)

OutputLine      = OutputBundle ;
OutputBundle    = ExpressionList ;

(* Canonical output precedence and shape:
       1. "..." — postfix spread binds to its immediate operand.
                        It opens that operand's evaluated sequence value into the
                        surrounding expression-list context.
      2. "," / adjacency — comma and allowed expression adjacency create a
               syntax-level expression list. Root output consumes a
               bare list as output slots, call syntax consumes it as
               argument slots, and parentheses materialize it as one
               sequence value.
      3. ";"   — unsupported expression syntax. It reports a targeted
               semicolon diagnostic and recovers as an expression-list separator.
    The tricky cases this precedence implies:
       F(1, 2, 3)      has three argument slots.
      F(1 2 3)        has three argument slots.
        F((1, 2, 3))    has one sequence-value argument.
         1, (2, 3)       has two output slots: 1 and sequence value (2, 3).
         A...B C         is A..., B, C.
       A, B...         keeps B... local to its comma slot.
    Parsing is purely syntactic: callable arity, runtime values, and
      inferred types never change comma, parentheses, or ellipsis behavior. *)

ExpressionList        = SequenceAtom { ExpressionListSeparator SequenceAtom } ;
ExpressionListSeparator = "," | ImplicitAdjacency ;
SequenceAtom          = Expression { "..." } ;
                     (* "..." is the POSTFIX spread operator.
                        It NEVER consumes a right operand: any token after
                        "..." — tight, spaced, or on the next physical line —
                        starts a new expression-list slot, so A...B,
                        A...empty, A... B, and A... <newline> B all parse as
                        A..., B (whitespace
                        before "..." stays insignificant). Postfix x... spreads
                        the evaluated sequence value of x into the surrounding
                        slot context and does not continue onto the next
                        physical line. The source token after the dots is
                        an ordinary expression-list contribution, never a right operand;
                        internally x... is a unary spread node over its single
                        operand, with no right operand. `X(a b...)` parses as X(a, b...).
                        (Prose says "spreads"; "opens" above is the slot-expansion
                        mechanism, not the `open` keyword.) *)
                     (* Semicolon is intentionally absent from ExpressionList.
                     `1 ; 2`, `A... ; B`, `Output = 1 ; 2`, and `F(1 ; 2)`
                     all report the unsupported-semicolon diagnostic.
                     ImplicitAdjacency is not a token: a complete expression
                     followed by the start of another complete expression
                     implies an expression-list separator where adjacency is
                     allowed. Same-line whitespace adjacency: 1 2 parses like
                     1, 2, F(1 2) is the two-argument call F(1, 2), and (1 2)
                     is the sequence value (1, 2). In output contexts, a
                     physical newline between complete expressions implies the
                     same expression-list separation. Postfix "..." applies only
                     to its immediate operand: A B... and A newline B... parse
                     as A, B....
                     Definition bodies and open targets are
                     line-bounded instead: a newline ends a definition body
                     unless a leading-dot continuation carries it on, and ends an open target list unless an
                     explicit comma (trailing or leading) or a leading-dot
                     continuation carries it on (a "("- or "{"-led line
                     never continues either), so properties, clauses, opens,
                     and Output definitions on later lines keep their
                     declaration meaning. Implicit expression-list separation is
                     inserted only when the next token cannot legally continue
                     the current expression; a token that continues it as a
                     postfix/call form on the same physical line wins over adjacency. In
                     particular a "(" or "{" after a callable target on the
                     same physical line is a call delimiter even across
                     whitespace, so F (1, 2) is the call F(1, 2) and A.B (1)
                     is the dot call A.B(1). A physical newline never
                     continues a closed expression into a call: F newline
                     (1, 2) is the expression list F, (1, 2) and A.B newline (1)
                     is A.B, (1). For a multiline call, open the delimiter
                     before the newline — F( newline 1, 2 newline ) is the
                     call F(1, 2) — because an already-open argument list or
                     brace block spans lines normally. Explicit comma keeps
                     expression-list structure: F, (1) has two slots, and
                     F newline (1) also has two slots. The "..." operator token
                     itself is line-bound and postfix-only: it must appear on
                     the same physical line as the expression it follows, and
                     it never takes a right operand — any token after the dots
                     starts a new expression. Adjacency
                     applies only between complete expressions: it never
                     splits identifiers or numbers, is never multiplication,
                     and a token sequence that begins a
                     property, clause, open, or Output definition is a
                     definition, not an adjacent expression. Physical line
                     boundaries are not structural groups, and parsing never
                     depends on callable arity. Newline adjacency produces an
                     expression-list separator.
                     THE PHYSICAL-LINE RULE in one sentence: a physical
                     newline ends a closed expression, and only a leading "."
                     (dot-chain continuation) or an
                     already-open "("/"{" delimiter may carry it across the
                     line — call delimiters, indexing ":", postfix grace "~",
                     binary operators, and the "..." token all require the
                     same physical line (write a trailing operator, e.g.
                     A - newline 1, to continue arithmetic). Comments are
                     semantically invisible for these decisions: A newline -1
                     and A // note newline -1 parse identically as the expression
                     list A, -1, never the subtraction A - 1. *)

Expression      = OrExpr ;
                  (* Binary operators are same-physical-line only: an
                     operator at the start of a line never continues the
                     previous line's expression (a "-"-led line is a new
                     unary-minus output row). A trailing operator does
                     continue: A - newline 1 is the subtraction. Skipped
                     comments never relax this boundary. *)
OrExpr          = XorExpr { "or" XorExpr } ;
XorExpr         = AndExpr { "xor" AndExpr } ;
AndExpr         = EqualityExpr { "and" EqualityExpr } ;
EqualityExpr    = ComparisonExpr { ( "==" | "!=" ) ComparisonExpr } ;
ComparisonExpr  = AdditiveExpr { ( "<" | ">" | "<=" | ">=" ) AdditiveExpr } ;
AdditiveExpr    = MultiplicativeExpr { ( "+" | "-" ) MultiplicativeExpr } ;
MultiplicativeExpr
              = PowerExpr { ( "*" | "/" | "div" | "mod" ) PowerExpr } ;
PowerExpr       = UnaryExpr [ "^" PowerExpr ] ;

UnaryExpr       = "-" UnaryExpr
                | "not" UnaryExpr
                | PostfixExpr ;

PostfixExpr     = Primary { PostfixOp } ;
PostfixOp       = ":" Primary   (* indexing is same-physical-line only: a ':'-led
                                   line never continues the previous expression and
                                   is a parse error. Same-line whitespace around ':'
                                   is insignificant (Pair:0, Pair :0, Pair : 0). *)
                | "." Identifier [ CallArgs ]
                                (* a '.'-led line intentionally continues the
                                   dot-call chain (method-chain layout). *)
                | CallArgs ;    (* only when LHS is a callable target: Resolve, DotCall, or Grace,
                                   and only when the call delimiter is on the same physical
                                   line as the callable expression's last token. Same-line
                                   whitespace continues the call, so F (1, 2) is the call
                                   F(1, 2), and the same holds for dot-call argument lists and
                                   brace argument lists. A physical newline never continues a
                                   closed expression into a call: F newline (1, 2) is the
                                   expression list F, (1, 2). Multiline calls open the delimiter
                                   before the newline; the already-open argument list spans
                                   lines normally. Non-callable targets never become calls:
                                   2 (3) and 2 newline (3) are the expression list 2, 3, never
                                   multiplication. *)

CallArgs        = BraceArgs | ParenArgs ;
BraceArgs       = "{" Algorithm "}" ;
ParenArgs       = "(" Algorithm ")" ;

Primary         = NumberLiteral
                | StringLiteral
                | EmptyLiteral
                | GraceIdentifier
                | ParenBundleExpr
                | BraceAlgorithmExpr ;

EmptyLiteral    = "empty" ;             (* explicit empty output; emits zero top-level values *)
GraceIdentifier = { "~" } Identifier { "~" } ;
                  (* postfix "~" is same-physical-line only: a "~"-led line
                     is its own prefix-grace expression, never postfix grace
                     on the previous line's identifier. *)
ParenBundleExpr = "(" Algorithm ")" ;
BraceAlgorithmExpr = "{" Algorithm "}" ;

NumberLiteral   = Number ;
Number          = /\d(_*\d)*(\.\d(_*\d)*)?(e[+-]?\d(_*\d)*)?/ ;
NonOutputIdentifier = Identifier ;       (* except reserved definition-position names "Output" and "empty" *)
Identifier      = /[A-Za-z_][A-Za-z0-9_]*/ ;
StringLiteral   = /'([^'\r\n])*'/ ;
Comment         = /\/\/[^\r\n]*/ ;
                  (* comments are semantically invisible: they never extend
                     or break a physical-line continuation decision. *)
